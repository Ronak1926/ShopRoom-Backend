generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id                  String   @id @default(cuid())
  fullName            String
  email               String   @unique
  passwordHash        String?
  firebaseUid         String?  @unique
  allowLocationAccess Boolean  @default(false)
  latitude            Float?
  longitude           Float?
  emailVerified       Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model EmailOtp {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Shopkeeper ───────────────────────────────────────────────────────────────

model ShopkeeperDraft {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  currentStep   Int      @default(1)
  data          Json     @default("{}")
  phoneVerified Boolean  @default(false)
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Shopkeeper {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  shopName          String
  shopCategory      String
  address           String
  city              String
  state             String
  pincode           String
  latitude          Float?
  longitude         Float?
  phoneNumber       String
  logoUrl           String?
  planType          String
  planExpiresAt     DateTime
  // ── Razorpay payment fields ─────────────────────────────────────────────────
  razorpayOrderId   String? // Razorpay order ID (order_xxx) created before checkout
  razorpayPaymentId String? // Razorpay payment ID (pay_xxx) captured after success
  // ── Stripe (commented out — replaced by Razorpay) ──────────────────────────
  // stripePaymentId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PhoneOtp {
  id          String   @id @default(cuid())
  phoneNumber String
  code        String
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([phoneNumber])
}
