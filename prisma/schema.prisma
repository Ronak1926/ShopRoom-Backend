generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id                  String   @id @default(cuid())
  fullName            String
  email               String   @unique
  passwordHash        String?
  firebaseUid         String?  @unique
  allowLocationAccess Boolean  @default(false)
  latitude            Float?
  longitude           Float?
  emailVerified       Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  memberships Membership[]
}

model EmailOtp {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Shopkeeper ───────────────────────────────────────────────────────────────

model ShopkeeperDraft {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  currentStep   Int      @default(1)
  data          Json     @default("{}")
  phoneVerified Boolean  @default(false)
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Shopkeeper {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  shopName          String
  shopCategory      String
  address           String
  city              String
  state             String
  pincode           String
  latitude          Float?
  longitude         Float?
  phoneNumber       String
  logoUrl           String?
  planType          String
  planExpiresAt     DateTime
  // ── Razorpay payment fields ─────────────────────────────────────────────────
  razorpayOrderId   String? // Razorpay order ID (order_xxx) created before checkout
  razorpayPaymentId String? // Razorpay payment ID (pay_xxx) captured after success
  // ── Stripe (commented out — replaced by Razorpay) ──────────────────────────
  // stripePaymentId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  shop Shop?
}

model PhoneOtp {
  id          String   @id @default(cuid())
  phoneNumber String
  code        String
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([phoneNumber])
}

// ─── Shop / Room ──────────────────────────────────────────────────────────────

/// The shop entity created after payment verification.
/// Distinct from Shopkeeper (auth + plan). One shopkeeper owns one shop.
model Shop {
  id      String     @id @default(cuid())
  ownerId String     @unique
  owner   Shopkeeper @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  shopName    String
  category    String
  description String?
  logoUrl     String?

  // Address
  address     String
  city        String
  state       String
  pincode     String
  phoneNumber String

  // Location — lat/lng for proximity queries, GeoJSON for API responses
  latitude    Float?
  longitude   Float?
  coordinates Json? // {"type":"Point","coordinates":[lng,lat]}

  // Back-reference: Room holds the FK (Room.shopId)
  room Room?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([ownerId])
}

/// The community room auto-created for every shop at registration.
model Room {
  id     String @id @default(cuid())
  shopId String @unique
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  inviteCode   String       @unique
  membersCount Int          @default(0)
  memberships  Membership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([inviteCode])
}

/// A customer's membership in a shop's room.
model Membership {
  id         String   @id @default(cuid())
  roomId     String
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  joinedAt             DateTime @default(now())
  notificationsEnabled Boolean  @default(true)

  @@unique([roomId, customerId])
  @@index([roomId])
  @@index([customerId])
}
